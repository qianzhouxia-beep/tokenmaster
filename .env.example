# TokenMaster v5 webhook env (PLACEHOLDER values only — DO NOT commit real secrets).

# PayPal Live App (rotate via PayPal dashboard if leaked).
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_WEBHOOK_URL=https://api-tokenmaster.com/paypal-webhook
# Sandbox base URL for local testing. Switch to https://api-m.paypal.com for live.
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# NOWPayments (crypto checkout).
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
NOWPAYMENTS_IPN_URL=https://api-tokenmaster.com/nowpayments-webhook

# New API (admin session cookie for minting redemption codes).
NEW_API_BASE_URL=https://api-tokenmaster.com
NEW_API_SESSION_COOKIE=your_newapi_admin_session_cookie_value

# SQLite path (relative to webhook/).
ORDERS_DB_PATH=orders.db

# Server port.
PORT=8000
